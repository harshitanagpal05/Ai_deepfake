# ── DeepScan Backend Environment Variables ────────────────────
# Copy this file to .env and fill in your values
#
# For Docker Compose: these are set in docker-compose.yml,
# so you only need .env when running outside Docker.
# ──────────────────────────────────────────────────────────────

PORT=5000
MONGODB_URI=mongodb://localhost:27017/deepscan
CORS_ORIGIN=http://localhost:3000
